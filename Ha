// Set up the Canvas
const canvas = document.getElementById('simulationCanvas');
const ctx = canvas.getContext('2d');

// -- Define the "World State" --

// 1. Define Jessica
const jessica = {
  x: 100, y: 300,        // Her starting position
  speed: 5,             // Her movement speed
  width: 50, height: 80, // Size of her character sprite
  isChased: false,
  sprite: new Image()  // JessicaInRobe.png
};
jessica.sprite.src = 'path_to_jessica_image.png';

// 2. Define the Stalls
const stalls = [
  { name: 'Coke Stand',    x: 200, y: 100, width: 100, height: 100 },
  { name: 'Waakye Seller', x: 600, y: 100, width: 100, height: 100 }
];

// 3. Define the Chickens
const chickens = [
  { x: 550, y: 150, speed: 1.5, active: false },
  { x: 580, y: 120, speed: 1.8, active: false }
];

// -- Set up Controls --
let keysDown = {};
window.addEventListener('keydown', (e) => keysDown[e.key] = true);
window.addEventListener('keyup', (e) => keysDown[e.key] = false);

// --- The Core Game Loop ---
function updateSimulation() {
  // Clear the screen
  ctx.clearRect(0, 0, canvas.width, canvas.height);

  // 1. Draw the Background and Stalls
  drawEnvironment();

  // 2. Process Input: Move Jessica
  if (keysDown['ArrowLeft']) jessica.x -= jessica.speed;
  if (keysDown['ArrowRight']) jessica.x += jessica.speed;
  if (keysDown['ArrowUp']) jessica.y -= jessica.speed;
  if (keysDown['ArrowDown']) jessica.y += jessica.speed;

  // 3. Keep Jessica on the screen (Boundary checks)
  keepInBounds(jessica);

  // 4. State Logic: Interact with Stalls
  processInteractions();

  // 5. Update Chickens (If they are chasing)
  if (jessica.isChased) {
    chickens.forEach(chicken => {
      // Very basic AI: Move directly toward Jessica
      if (chicken.x < jessica.x) chicken.x += chicken.speed;
      if (chicken.x > jessica.x) chicken.x -= chicken.speed;
      if (chicken.y < jessica.y) chicken.y += chicken.speed;
      if (chicken.y > jessica.y) chicken.y -= chicken.speed;

      // Draw the chicken
      drawChicken(chicken);

      // Check if chicken caught Jessica (Collision)
      if (checkCollision(chicken, jessica)) {
        alert("Caught! Jessica drops the chicken.");
        resetSimulation();
      }
    });
  }

  // 6. Draw Jessica (in her robe!)
  ctx.drawImage(jessica.sprite, jessica.x, jessica.y, jessica.width, jessica.height);

  // Loop the function
  requestAnimationFrame(updateSimulation);
}

// --- Helper Functions (The Logic) ---

function processInteractions() {
  // Check if Jessica collides with the Coke Stand (Collision Detection)
  if (checkCollision(jessica, stalls[0])) {
    console.log("Jessica gets chicken!");
    stalls[0].hasChicken = false; // "Stolen" state
  }

  // Check if Jessica collides with the Waakye Seller (Collision Detection)
  if (checkCollision(jessica, stalls[1])) {
    console.log("Chickens angered! The chase is on!");
    jessica.isChased = true;
  }
}

function checkCollision(rect1, rect2) {
  // Classic AABB (Axis-Aligned Bounding Box) collision test
  return rect1.x < rect2.x + rect2.width &&
         rect1.x + rect1.width > rect2.x &&
         rect1.y < rect2.y + rect2.height &&
         rect1.height + rect1.y > rect2.y;
}

function drawEnvironment() { /* Code to draw stalls/signs */ }
function drawChicken(chicken) { /* Code to draw chicken sprite */ }
function keepInBounds(entity) { /* Code to stop entity at canvas edge */ }
function resetSimulation() { /* Reset positions and states */ }

// --- Start the Loop ---
updateSimulation();
